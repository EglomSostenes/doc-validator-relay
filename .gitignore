.env
.env.local
.env.*.local

# ── Cobertura de testes ───────────────────────────────────────────────────────
coverage.out
coverage.html

# ── IDEs e editores ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
