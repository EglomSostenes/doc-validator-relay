# ── Postgres (Rails DB — do not change the DB name) ───────────────────────────
POSTGRES_USER=doc_validator
POSTGRES_PASSWORD=senha123
# DATABASE_URL is assembled in docker-compose.yml from the vars above.
# Override here only if running the relay outside Docker.
# DATABASE_URL=postgresql://doc_validator:senha123@localhost:5433/doc_validator_development

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=doc_validator
RABBITMQ_PASSWORD=senha123
RABBITMQ_HOST=rabbitmq       # service name inside Docker; use localhost outside
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=doc_validator.events

# ── Relay tuning (all optional — shown with defaults) ─────────────────────────
# How many events to claim per poll cycle
# RELAY_BATCH_SIZE=100

# How long to wait between polls when the queue is empty
# RELAY_POLL_INTERVAL=3s

# Max concurrent publish goroutines
# RELAY_WORKER_COUNT=10

# How long an event can stay in "processing" before being reclaimed.
# Deve ser maior que o tempo total de retry do markPublished
# (5 tentativas × backoff máx ~1.6s + margem = ~30s é suficiente,
#  mas 10min dá margem confortável para falhas de banco prolongadas)
RELAY_PROCESSING_TIMEOUT=10m

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to "production" for JSON log output
# GO_ENV=development
